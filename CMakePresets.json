{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "TOOLX_BUILD_TESTS": "ON",
        "TOOLX_BUILD_EXAMPLES": "ON",
        "TOOLX_BUILD_TOOLS": "ON",
        "TOOLX_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "dev",
      "inherits": "base",
      "displayName": "ToolX Dev",
      "description": "Default local development configure preset."
    },
    {
      "name": "clang-tidy",
      "inherits": "base",
      "displayName": "ToolX Clang-Tidy",
      "description": "Development preset with clang-tidy enabled.",
      "cacheVariables": {
        "TOOLX_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "coverage",
      "inherits": "base",
      "displayName": "ToolX Coverage",
      "description": "Coverage-instrumented configure preset for GCC/Clang-like toolchains.",
      "cacheVariables": {
        "TOOLX_ENABLE_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "clang-tidy",
      "configurePreset": "clang-tidy"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "targets": [
        "coverage"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "clang-tidy",
      "configurePreset": "clang-tidy",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
